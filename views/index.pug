extends layout

block content
  h1= title
  p Welcome to #{title}
  
  //- Part 4 Button and Logic [cite: 79, 107, 111]
  button(type="button", class="btn btn-secondary", onclick="reduce()") Sample Button
  div#use(class="mt-3") take some away

  script.
    let current = 11;
    let quantity = 2;
    function reduce() {
      current -= quantity;
      if (current < 0) current = 0;
      document.getElementById('use').innerText = `Reduced by ${quantity} to ${current}`;
    }

  //- Step 8: Hyperlink to the tires endpoint 
  br
  a(href="/tires") View Tire Results
extends layout

block content
  h1= title
  p Welcome to #{title}. This is a server-side change.
  button(type="button", class="btn btn-secondary", onclick="reduce()") Sample Button
  div#use 
  script.
    let current = 11;
    let quantity = 2;

    function reduce() {
      current -= quantity;
      if (current < 0) {
        current = 0;
      }
      document.getElementById('use').innerText = `Reduced by ${quantity} to ${current}`;
    }
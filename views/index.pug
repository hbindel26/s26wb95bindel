extends layout

block content
  h1= title
  p Welcome to #{title}
  // Step 4: Add onclick to the button
  button(type="button", class="btn btn-secondary", onclick="reduce()") Sample Button

  // Step 1: Add the div
  div#use(class="mt-3") take some away

  // Step 3: Add the script block
  script.
    let current = 11;
    let quantity = 2;
    function reduce() {
      current -= quantity;
      if (current < 0) current = 0;
      document.getElementById('use').innerText = `Reduced by ${quantity} to ${current}`;
    }